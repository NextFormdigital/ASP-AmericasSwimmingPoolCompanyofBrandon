<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ASP - America's Swimming Pool Company of Brandon</title>

<style>
body {
  margin: 0;
  font-family: 'Segoe UI', sans-serif;
  background: #0b1220;
  color: #e2e8f0;
}

header {
  display: flex;
  justify-content: space-between;
  padding: 20px;
  background: #020617;
}

nav a {
  color: #22d3ee;
  text-decoration: none;
  margin-left: 15px;
}

.hero {
  text-align: center;
  padding: 100px 20px;
  background: linear-gradient(to right, #0ea5e9, #22d3ee);
  color: #020617;
}

.cta {
  display: inline-block;
  margin-top: 20px;
  padding: 12px 24px;
  background: #020617;
  color: #22d3ee;
  text-decoration: none;
  border-radius: 6px;
  cursor: pointer;
}

.section {
  padding: 60px 20px;
  text-align: center;
}

.buttons button {
  margin: 8px;
  padding: 10px 16px;
  border: none;
  background: #22d3ee;
  color: #020617;
  border-radius: 6px;
  cursor: pointer;
  transition: 0.2s;
}

.buttons button:hover {
  transform: scale(1.05);
}

#service-display {
  margin-top: 20px;
  padding: 20px;
  background: #1e293b;
  border-radius: 8px;
}

form {
  display: flex;
  flex-direction: column;
  max-width: 400px;
  margin: auto;
}

input, select, button {
  margin: 10px 0;
  padding: 12px;
  border-radius: 6px;
  border: none;
}

button {
  background: #22d3ee;
  cursor: pointer;
}

.hidden {
  display: none;
}
</style>

</head>

<body>

<header>
  <h2>ASP Brandon</h2>
  <nav>
    <a onclick="showPage('home')">Home</a>
    <a onclick="showPage('booking')">Book Now</a>
  </nav>
</header>

<!-- HOME -->
<div id="home">

<section class="hero">
  <h1>Crystal Clear Pools, Zero Stress</h1>
  <p>Luxury pool care for homes and businesses in Brandon, Florida.</p>
  <button class="cta" onclick="showPage('booking')">Book a Service</button>
</section>

<section class="section">
  <h2>Our Services</h2>

  <div class="buttons">
    <button onclick="showService('pool_cleaning')">Pool Cleaning</button>
    <button onclick="showService('commercial')">Commercial</button>
    <button onclick="showService('equipment')">Equipment Repair</button>
    <button onclick="showService('one_time')">One-Time</button>
    <button onclick="showService('ongoing')">Ongoing</button>
    <button onclick="showService('seasonal')">Seasonal</button>
    <button onclick="showService('tile')">Tile Cleaning</button>
    <button onclick="showService('water')">Water Balancing</button>
  </div>

  <div id="service-display">
    <p>Select a service to learn more.</p>
  </div>
</section>

<section class="section">
  <h2>Our Location</h2>
  <iframe 
    src="https://www.google.com/maps?q=3402+Cypress+Landing+Drive+Valrico+Florida+33596&output=embed"
    width="100%" height="300" style="border:0;" allowfullscreen="">
  </iframe>
</section>

</div>

<!-- BOOKING -->
<div id="booking" class="hidden">

<section class="section">
  <h2>Book Your Pool Service</h2>

  <form id="bookingForm">
    <input type="text" id="name" placeholder="Your Name" required>
    <input type="email" id="email" placeholder="Email" required>

    <select id="service" required>
      <option value="">Select Service</option>
      <option>Pool Cleaning</option>
      <option>Commercial Pool Cleaning</option>
      <option>Equipment Repair</option>
      <option>One-Time Cleaning</option>
      <option>Ongoing Cleaning</option>
      <option>Seasonal Opening/Closing</option>
      <option>Tile Cleaning</option>
      <option>Water Testing & Balancing</option>
    </select>

    <input type="date" id="date" required>

    <button type="submit">Confirm Booking</button>
  </form>

  <p id="confirmation"></p>
</section>

</div>

<script>
function showPage(page) {
  document.getElementById('home').classList.add('hidden');
  document.getElementById('booking').classList.add('hidden');

  document.getElementById(page).classList.remove('hidden');
}

function showService(service) {
  const display = document.getElementById("service-display");

  const content = {
    pool_cleaning: "Complete cleaning to keep your pool crystal clear and swim-ready.",
    commercial: "Reliable large-scale pool maintenance for businesses and facilities.",
    equipment: "Repair and maintenance of pumps, filters, and pool systems.",
    one_time: "Deep cleaning for special occasions or neglected pools.",
    ongoing: "Scheduled weekly or bi-weekly maintenance services.",
    seasonal: "Opening and closing services to prepare for season changes.",
    tile: "Professional tile and wall cleaning for a polished look.",
    water: "Accurate water testing and chemical balancing for safety."
  };

  display.innerHTML = `<p>${content[service]}</p>`;
}

document.getElementById("bookingForm").addEventListener("submit", function(e) {
  e.preventDefault();

  const name = document.getElementById("name").value;

  document.getElementById("confirmation").innerText =
    "Thanks " + name + "! Your booking request has been received.";

  this.reset();
});
</script>

</body>
</html>
